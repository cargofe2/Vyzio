// VYZIO — Prisma Schema (PostgreSQL)
// Run: npx prisma migrate dev --name init

generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

enum Plan { STARTER PRO PREMIUM FAMILY SCHOOL ENTERPRISE }
enum LessonType { VIDEO READING QUIZ PROJECT EVALUATION PRACTICE }
enum MissionType { DAILY WEEKLY MONTHLY TOURNAMENT GLOBAL BATTLE }
enum RankTier { NOVICE EXPLORER CREATOR BUILDER INNOVATOR VISIONARY PIONEER MASTER LEGEND AI_TITAN }
enum CertificateLevel { EXPLORER CREATOR BUILDER ENTREPRENEUR MASTER }
enum SubscriptionStatus { ACTIVE CANCELED PAST_DUE TRIALING INCOMPLETE }

model Level { id String @id @default(cuid()); number Int @unique; name String; slug String @unique; description String; xpRequired Int @default(0); isFree Boolean @default(false); order Int; worlds World[]; certificates Certificate[]; createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@map("levels") }
model World { id String @id @default(cuid()); number Int; name String; slug String @unique; description String; emoji String @default("🌍"); order Int; xpReward Int @default(500); levelId String; level Level @relation(fields: [levelId], references: [id]); lessons Lesson[]; progress WorldProgress[]; createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@unique([levelId, number]); @@map("worlds") }
model Lesson { id String @id @default(cuid()); number Int; title String; slug String @unique; type LessonType; description String?; content Json?; videoUrl String?; durationMin Int @default(5); xpReward Int @default(75); order Int; isPublished Boolean @default(false); worldId String; world World @relation(fields: [worldId], references: [id]); quizQuestions QuizQuestion[]; progress LessonProgress[]; createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@unique([worldId, number]); @@map("lessons") }
model QuizQuestion { id String @id @default(cuid()); question String; options String[]; correctIndex Int; explanation String; order Int; lessonId String; lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade); attempts QuizAttempt[]; @@map("quiz_questions") }
model User { id String @id @default(cuid()); clerkId String @unique; email String @unique; username String @unique; displayName String; avatarUrl String?; avatarEmoji String @default("🧑‍💻"); bio String?; isPublicProfile Boolean @default(true); parentId String?; parent User? @relation("ParentChild", fields: [parentId], references: [id]); children User[] @relation("ParentChild"); createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; lastSeenAt DateTime @default(now()); gamification Gamification?; subscription Subscription?; lessonProgress LessonProgress[]; worldProgress WorldProgress[]; quizAttempts QuizAttempt[]; achievements UserAchievement[]; missionProgress MissionProgress[]; certificates Certificate[]; portfolioItems PortfolioItem[]; vyMessages VyMessage[]; teamMemberships TeamMember[]; createdTeams Team[]; @@map("users") }
model Gamification { id String @id @default(cuid()); xpTotal Int @default(0); xpWeekly Int @default(0); gems Int @default(0); vyCoins Int @default(0); energy Int @default(100); rank RankTier @default(NOVICE); rankLevel Int @default(1); streakDays Int @default(0); streakMax Int @default(0); lastStudyDate DateTime?; xpMultiplier Float @default(1.0); lessonsCompleted Int @default(0); quizPerfect Int @default(0); projectsPublished Int @default(0); daysStudied Int @default(0); tournamentsWon Int @default(0); userId String @unique; user User @relation(fields: [userId], references: [id], onDelete: Cascade); xpEvents XpEvent[]; createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@map("gamification") }
model XpEvent { id String @id @default(cuid()); amount Int; reason String; meta Json?; gamificationId String; gamification Gamification @relation(fields: [gamificationId], references: [id], onDelete: Cascade); createdAt DateTime @default(now()); @@map("xp_events") }
model LessonProgress { id String @id @default(cuid()); completed Boolean @default(false); completedAt DateTime?; score Int?; xpEarned Int @default(0); attempts Int @default(0); timeSpentSec Int @default(0); videoWatchPct Float @default(0); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); lessonId String; lesson Lesson @relation(fields: [lessonId], references: [id]); createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@unique([userId, lessonId]); @@map("lesson_progress") }
model WorldProgress { id String @id @default(cuid()); pctComplete Float @default(0); completed Boolean @default(false); completedAt DateTime?; xpEarned Int @default(0); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); worldId String; world World @relation(fields: [worldId], references: [id]); @@unique([userId, worldId]); @@map("world_progress") }
model QuizAttempt { id String @id @default(cuid()); selectedIndex Int; isCorrect Boolean; isPerfect Boolean @default(false); timeSpentSec Int @default(0); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); questionId String; question QuizQuestion @relation(fields: [questionId], references: [id]); createdAt DateTime @default(now()); @@map("quiz_attempts") }
model Achievement { id String @id @default(cuid()); slug String @unique; name String; description String; emoji String; rarity String; xpBonus Int @default(0); gemBonus Int @default(0); triggerType String; triggerValue Int; users UserAchievement[]; @@map("achievements") }
model UserAchievement { id String @id @default(cuid()); earnedAt DateTime @default(now()); notified Boolean @default(false); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); achievementId String; achievement Achievement @relation(fields: [achievementId], references: [id]); @@unique([userId, achievementId]); @@map("user_achievements") }
model Mission { id String @id @default(cuid()); slug String @unique; name String; description String; type MissionType; xpReward Int; gemReward Int @default(0); coinReward Int @default(0); startsAt DateTime?; endsAt DateTime?; isActive Boolean @default(true); targetType String; targetValue Int; progress MissionProgress[]; createdAt DateTime @default(now()); @@map("missions") }
model MissionProgress { id String @id @default(cuid()); current Int @default(0); completed Boolean @default(false); completedAt DateTime?; rewardClaimed Boolean @default(false); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); missionId String; mission Mission @relation(fields: [missionId], references: [id]); @@unique([userId, missionId]); @@map("mission_progress") }
model Certificate { id String @id @default(cuid()); uuid String @unique @default(cuid()); level CertificateLevel; issuedAt DateTime @default(now()); pdfUrl String?; verifyUrl String; qrCodeUrl String?; lessonsCompleted Int; projectsCompleted Int; totalXpAtIssuance Int; userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); levelId String; courseLevel Level @relation(fields: [levelId], references: [id]); @@map("certificates") }
model PortfolioItem { id String @id @default(cuid()); title String; description String; projectType String; tools String[]; thumbnailUrl String?; projectUrl String?; isPublic Boolean @default(true); score Int?; xpEarned Int @default(0); viewCount Int @default(0); likeCount Int @default(0); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); lessonId String?; createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@map("portfolio_items") }
model VyMessage { id String @id @default(cuid()); role String; content String; tokens Int?; userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); createdAt DateTime @default(now()); @@index([userId, createdAt]); @@map("vy_messages") }
model Team { id String @id @default(cuid()); name String; slug String @unique; description String?; emoji String @default("⚡"); isPublic Boolean @default(true); maxMembers Int @default(6); totalXpWeekly Int @default(0); creatorId String; creator User @relation(fields: [creatorId], references: [id]); members TeamMember[]; createdAt DateTime @default(now()); @@map("teams") }
model TeamMember { id String @id @default(cuid()); role String @default("member"); joinedAt DateTime @default(now()); teamId String; team Team @relation(fields: [teamId], references: [id], onDelete: Cascade); userId String; user User @relation(fields: [userId], references: [id], onDelete: Cascade); @@unique([teamId, userId]); @@map("team_members") }
model Subscription { id String @id @default(cuid()); plan Plan @default(STARTER); status SubscriptionStatus @default(ACTIVE); stripeCustomerId String? @unique; stripeSubscriptionId String? @unique; stripePriceId String?; currentPeriodStart DateTime?; currentPeriodEnd DateTime?; cancelAtPeriodEnd Boolean @default(false); trialEnd DateTime?; seatCount Int?; schoolName String?; invoiceEmail String?; userId String @unique; user User @relation(fields: [userId], references: [id], onDelete: Cascade); createdAt DateTime @default(now()); updatedAt DateTime @updatedAt; @@map("subscriptions") }
