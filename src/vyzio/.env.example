# VYZIO — Environment Variables
# Copy to .env.local and fill in your values

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Get from Railway, Supabase, or local Docker
DATABASE_URL="postgresql://vyzio:password@localhost:5432/vyzio?schema=public"

# ── Clerk Auth ────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...  # from Clerk Dashboard → Webhooks

# ── Anthropic (VY Tutor) ──────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────
# https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # run: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_FAMILY_ANNUAL=price_...
STRIPE_PRICE_SCHOOL_ANNUAL=price_...

# ── Pinecone (RAG for VY) ─────────────────────────────────────
# https://app.pinecone.io
PINECONE_API_KEY=...
PINECONE_INDEX=vyzio-content
PINECONE_ENVIRONMENT=us-east-1-aws

# ── OpenAI (Embeddings for Pinecone) ─────────────────────────
OPENAI_API_KEY=sk-...

# ── Upstash Redis (Leaderboards + Cache) ─────────────────────
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Cloudflare R2 (Videos, Certificates, Avatars) ────────────
# https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=vyzio-assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.vyzio.ai
